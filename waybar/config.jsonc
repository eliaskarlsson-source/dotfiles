{
  "layer": "top",
  "position": "top",
  "height": 56,
  "margin": "8 8 0 8",
  "spacing": 4,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "cpu", "memory", "temperature", "network", "battery", "tray"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "َ°ژ¤",
      "2": "َ°ژ§",
      "3": "َ°ژھ",
      "4": "َ°ژ­",
      "5": "َ°ژ°",
      "6": "َ°ژ¶",
      "7": "َ°ژ¹",
      "8": "َ°ژ¼",
      "9": "َ°½½",
      "10": "َ°½¾"
    },
    "persistent_workspaces": {
      "*": 5
    },
    "on-click": "activate"
  },

  "hyprland/window": {
    "format": "َ°–¯ {}",
    "separate-outputs": true,
    "max-length": 50,
    "rewrite": {
      "(.*) â€” Mozilla Firefox": "َ°ˆ¹ $1",
      "(.*) â€” Visual Studio Code": "َ°¨‍ $1",
      "(.*) â€” Thunar": "َ°‰‹ $1",
      "(.*) â€” Kitty": "َ°†چ $1"
    }
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "َ°ƒ­ {:%A, %B %d, %Y, %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode"
    },
    "on-click": "gnome-calendar"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں muted",
    "format-bluetooth": "َ°‚¯ {volume}%",
    "format-bluetooth-muted": "َ°‚² muted",
    "format-source": "َ°چ¬ {volume}%",
    "format-source-muted": "َ°چ­ muted",
    "format-icons": {
      "headphone": "َ°‹‹",
      "hands-free": "َ°‹‹",
      "headset": "َ°‹‹",
      "phone": "َ°„œ",
      "portable": "َ°‹‹",
      "car": "َ°„‹",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },

  "cpu": {
    "format": "َ°»  {usage}%",
    "interval": 2,
    "tooltip": true,
    "on-click": "gnome-system-monitor"
  },

  "memory": {
    "format": "َ°چ› {used:0.1f}G/{total:0.1f}G",
    "interval": 5,
    "tooltip": true,
    "on-click": "gnome-system-monitor"
  },

  "temperature": {
    "thermal-zone": 1,
    "critical-threshold": 90,
    "format": "َ°”ڈ {temperatureC}آ°C",
    "format-icons": ["َ°”ڈ", "َ°”ڈ", "َ°”ڈ"],
    "tooltip": true
  },

  "network": {
    "format-wifi": "َ°¤¨ {essid} ({signalStrength}%)",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "format-linked": "َ°ˆ€ {ifname} (No IP)",
    "format-disconnected": "َ°¤­ Disconnected",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) - {ipaddr}",
    "tooltip-format-ethernet": "{ifname} - {ipaddr}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "nm-connection-editor"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-plugged": "َ°‚„ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
  },

  "tray": {
    "icon-size": 18,
    "spacing": 8,
    "show-passive-items": true
  }
}
